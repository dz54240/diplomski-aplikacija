source "https://rubygems.org"

# Bundle edge Rails instead: gem "rails", github: "rails/rails", branch: "main"
gem "rails", "~> 8.1.3"

# Use postgresql as the database for Active Record
gem "pg", "~> 1.1"

# pgvector ActiveRecord integration. Registers the vector type with AR so
# `chunks.embedding` round-trips as a Ruby Array (instead of String). Adds the
# `has_neighbors :embedding` DSL ready for Rails-side vector queries
# (e.g. admin debugging, hybrid rerank). Node-agent still does all production
# vector reads/writes directly via pg for performance.
gem "neighbor", "~> 0.5"


# Use the Puma web server [https://github.com/puma/puma]
gem "puma", ">= 5.0"

# Windows does not include zoneinfo files, so bundle the tzinfo-data gem
gem "tzinfo-data", platforms: %i[ windows jruby ]

# Reduces boot times through caching; required in config/boot.rb
gem "bootsnap", require: false

# Use Active Storage variants [https://guides.rubyonrails.org/active_storage_overview.html#transforming-images]
# Used for document image variants; gem ships so the Dockerfile builds reproducibly.
gem "image_processing", "~> 1.2"

# Cross-origin requests from the Vite client (localhost:5173).
gem "rack-cors"

# Auth + authorization.
gem "bcrypt", "~> 3.1"           # has_secure_password
gem "jwt", "~> 2.9"               # HS256 encode/decode for access tokens
gem "pundit", "~> 2.4"            # deny-first authorization
gem "rack-attack", "~> 6.7"       # rate limiting

# Background jobs.
gem "sidekiq", "~> 7.3"

# Active Storage S3 adapter — used to talk to MinIO in dev and AWS S3 in prod.
gem "aws-sdk-s3", "~> 1.170", require: false

gem "faraday", "~> 2.10"

# Read .env in development. Production envs supply real env vars.
gem "dotenv-rails", groups: %i[development test]

group :development, :test do
  # See https://guides.rubyonrails.org/debugging_rails_applications.html#debugging-with-the-debug-gem
  gem "debug", platforms: %i[ mri windows ], require: "debug/prelude"

  # Audits gems for known security defects (use config/bundler-audit.yml to ignore issues)
  gem "bundler-audit", require: false

  # Static analysis for security vulnerabilities [https://brakemanscanner.org/]
  gem "brakeman", require: false
end
