# ─────────────────────────────────────────────────────────────────────────────
# Environment template. Copy to `.env` and fill in real values.
#
# Hybrid dev model: infra runs in Docker (`make infra`), application services
# run on the host. Hostnames below are `localhost` because the host *is* the
# runtime. Inside containers the same vars get overridden with service-name
# hostnames (e.g. `postgres`, `redis`).
# ─────────────────────────────────────────────────────────────────────────────

# Postgres (used by Rails + Node directly).
# Host port is 5433 (not 5432) to avoid clashing with a system-installed
# Postgres many devs run on the default port. Inside the container Postgres
# still listens on 5432; Docker port-forwards 5433->5432.
POSTGRES_USER=studyapp
POSTGRES_PASSWORD=studyapp
POSTGRES_DB=studyapp_dev
POSTGRES_PORT=5433
DATABASE_URL=postgres://studyapp:studyapp@127.0.0.1:5433/studyapp_dev
TEST_DATABASE_URL=postgres://studyapp:studyapp@127.0.0.1:5433/studyapp_test

# Redis (Sidekiq queue)
REDIS_URL=redis://127.0.0.1:6379/0

# MinIO (S3-compatible object storage)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET=study-materials
MINIO_ENDPOINT=http://127.0.0.1:9000
MINIO_REGION=us-east-1

# ─── Rails secrets ──────────────────────────────────────────────────────────
# This project does NOT use Rails encrypted credentials (no config/credentials.yml.enc).
# All Rails secrets flow through ENV exclusively; dotenv-rails loads this file
# automatically in dev/test. Rationale: no master.key out-of-band sharing, one
# source of truth.

# Used by Rails to sign session cookies and MessageVerifier. Required in
# RAILS_ENV=production. In dev/test Rails auto-generates a temp key in
# tmp/local_secret.txt if this var is unset, so it's optional locally.
# Generate with: `openssl rand -hex 64`
SECRET_KEY_BASE=

# JWT (Rails mints; each consumer service hardcodes its own audience identity).
# python-parser expects aud="python-parser"; node-agent expects aud="node-agent".
# Rails passes `audience:` explicitly when minting, so there is no shared JWT_AUDIENCE here.
JWT_SECRET=change-me-in-real-env-please
JWT_ISSUER=rails-api

# OpenAI
OPENAI_API_KEY=sk-...

# Inter-service URLs (used when Rails calls Node, Node calls Python, etc.)
RAILS_API_URL=http://localhost:3000
NODE_AGENT_URL=http://localhost:4000
PYTHON_PARSER_URL=http://localhost:8000

# Client (Vite reads VITE_*-prefixed vars at build time)
VITE_RAILS_API_URL=http://localhost:3000
VITE_NODE_AGENT_URL=http://localhost:4000

# Origins allowed by Rails CORS for cross-origin requests (Vite dev server,
# Vercel preview hostnames in prod). Comma-separated.
CORS_ORIGINS=http://localhost:5173

# Sidekiq Web UI (dev/test only, mounted at /sidekiq).
SIDEKIQ_USER=admin
SIDEKIQ_PASS=sidekiq-dev
