{
  "name": "node-agent",
  "version": "0.1.0",
  "private": true,
  "description": "Vercel AI SDK 6 agent runtime for the agentic study assistant.",
  "type": "module",
  "main": "src/server.ts",
  "scripts": {
    "dev": "tsx watch --env-file=../.env src/server.ts",
    "start": "node --import tsx src/server.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint ."
  },
  "dependencies": {
    "@ai-sdk/openai": "^2.0.106",
    "@aws-sdk/client-s3": "^3.1049.0",
    "@aws-sdk/s3-request-presigner": "^3.1049.0",
    "ai": "^6.0.0",
    "cors": "^2.8.6",
    "dotenv": "^17.0.0",
    "express": "^5.0.0",
    "jsonwebtoken": "^9.0.2",
    "openai": "^6.37.0",
    "p-limit": "^7.3.0",
    "pg": "^8.13.0",
    "pg-format": "^1.0.4",
    "pino": "^10.3.1",
    "tiktoken": "^1.0.22",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.16.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.10.0",
    "@types/pg": "^8.11.0",
    "@types/pg-format": "^1.0.5",
    "eslint": "^9.16.0",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.18.0"
  },
  "packageManager": "pnpm@10.23.0",
  "engines": {
    "node": ">=22"
  }
}
